// This is your Prisma schema file,

// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int     @id @default(autoincrement())
  username String  @unique
  password String
  orders   Order[]
}

enum OrderSide {
  BUY
  SELL
}

enum OrderStatus {
  PENDING // Sitting in B+ Tre
  PARTIALLY_FILLED // Partially matched
  FILLED // Fully matched
  CANCELLED
}

model Order {
  id     String @id @default(uuid())
  userId Int
  symbol String // e.g., "BTC_USDT"
  side OrderSide
  price Float
  quantity Float
  remainingQty Float // Important for partial fills
  status OrderStatus @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  externalId String? @unique
  // Relations

  user User @relation(fields: [userId], references: [id])
}

model Trade {
  id String @id @default(uuid())
  symbol String
  price Float
  quantity Float
  takerOrderId String
  makerOrderId String
  executedAt DateTime @default(now())
}

model ExternalTrade {
  id String @id @default(uuid())
  symbol String
  price Float
  quantity Float
  timestamp DateTime
  externalId String? // The trade ID from Binance (raw.t)
  @@index([symbol, timestamp])
}
